PORT=8080
HOST=0.0.0.0
JWT_SECRET=hepai-dev-secret-change-in-production
# SQLite（默认，无需安装 MySQL）
SQLITE_PATH=./data/hepai.sqlite

# 钉钉插件试点（可选，配置后支持 JSAPI 免登）
# DINGTALK_APP_KEY=
# DINGTALK_APP_SECRET=
# DINGTALK_CORP_ID=
# DINGTALK_AGENT_ID=

# 前端 build 产物目录（pilot-dingtalk 脚本会自动设置）
# FRONTEND_DIST=../和拍---新人入职社交互助平台/dist

# 额外 CORS 源（逗号分隔，一般同源部署不需要）
# CORS_ORIGINS=https://hepai.example.com

# 配置后 AI HR 对话将使用 Gemini（否则为智能演示回复）
GEMINI_API_KEY=

# 若使用 MySQL，取消注释并配置（同时需运行 text/db/*.sql）
# DB_DRIVER=mysql
# MYSQL_HOST=127.0.0.1
# MYSQL_PORT=3306
# MYSQL_USER=root
# MYSQL_PASSWORD=your_password
# MYSQL_DATABASE=hepai
