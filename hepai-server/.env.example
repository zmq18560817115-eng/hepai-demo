PORT=8080
JWT_SECRET=hepai-dev-secret-change-in-production
# SQLite（默认，无需安装 MySQL）
SQLITE_PATH=./data/hepai.sqlite

# 配置后 AI HR 对话将使用 Gemini（否则为智能演示回复）
GEMINI_API_KEY=

